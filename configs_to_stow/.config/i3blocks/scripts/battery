#!/bin/bash

# Battery status with color coding and desktop notification.
# Color thresholds:
#   Red:    < 10% — sends a critical notify-send notification (once per level)
#   Orange: < 20%
#   Yellow: < 40%
#   Default: >= 40%
# Click to cycle power profiles is handled separately in power_profile script.

bat_path="/sys/class/power_supply/BAT0"
notif_file="/tmp/i3blocks_battery_notified"

if [ -d "$bat_path" ]; then
    status=$(cat "$bat_path/status")
    capacity=$(cat "$bat_path/capacity")
    energy=$(cat "$bat_path/energy_now" 2>/dev/null)
    power=$(cat "$bat_path/power_now" 2>/dev/null)

    # Calculate remaining time from energy/power (microwatt-hours / microwatts)
    if [ -n "$energy" ] && [ -n "$power" ] && [ "$power" -gt 0 ]; then
        hours=$((energy / power))
        minutes=$(( (energy % power) * 60 / power ))
        remaining=$(printf "%02d:%02d" $hours $minutes)
    else
        remaining=""
    fi

    # Set color based on capacity and send notification at critical level
    if [ "$capacity" -lt 10 ]; then
        color="#FF0000"
        if [ "$status" = "Discharging" ]; then
            last_notified=$(cat "$notif_file" 2>/dev/null)
            if [ "$last_notified" != "$capacity" ]; then
                notify-send -u critical "Battery Critical" "Battery at ${capacity}% — plug in now!"
                echo "$capacity" > "$notif_file"
            fi
        fi
    elif [ "$capacity" -lt 20 ]; then
        color="#FFA500"
        rm -f "$notif_file"
    elif [ "$capacity" -lt 40 ]; then
        color="#FFFF00"
        rm -f "$notif_file"
    else
        rm -f "$notif_file"
    fi

    # Build display text based on charging status
    if [ "$status" = "Charging" ]; then
        text="↑${capacity}% $remaining"
    elif [ "$status" = "Not charging" ]; then
        text="AC ${capacity}%"
    elif [ "$status" = "Full" ]; then
        text="AC ${capacity}%"
    else
        text="↓${capacity}% $remaining"
    fi

    # Output with pango color markup if a color was set
    if [ -n "$color" ]; then
        echo "<span foreground=\"${color}\">${text}</span>"
    else
        echo "$text"
    fi
else
    echo "AC"
fi
