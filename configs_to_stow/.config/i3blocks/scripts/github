#!/bin/bash

if [ "$BLOCK_BUTTON" = "1" ]; then
    xdg-open https://github.com/notifications 2>/dev/null &
fi

count=$(gh api notifications 2>/dev/null | python3 -c "import sys,json; print(len(json.load(sys.stdin)))" 2>/dev/null)
if [ -n "$count" ] && [ "$count" -gt 0 ]; then
    echo "🔀 $count"
fi
