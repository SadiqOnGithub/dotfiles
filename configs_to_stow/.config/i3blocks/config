command=~/.config/i3blocks/scripts/$BLOCK_NAME
separator_block_width=15
markup=pango

# [ipv6]
# command=ip -6 addr show scope global | grep -oP 'inet6 \K[^/]+' | head -n1
# interval=30

[wireless]
command=~/.config/i3blocks/scripts/wireless
interval=5

[ethernet]
command=~/.config/i3blocks/scripts/ethernet
interval=10

[vpn]
command=~/.config/i3blocks/scripts/vpn
interval=10

[dns]
command=~/.config/i3blocks/scripts/dns
interval=30

[latency]
command=~/.config/i3blocks/scripts/latency
interval=30

[network_speed]
command=~/.config/i3blocks/scripts/network_speed
interval=1

[cpu]
command=~/.config/i3blocks/scripts/cpu
interval=1

[memory]
command=~/.config/i3blocks/scripts/memory
interval=10

[disk_root]
# / and /home share the same partition on this system
command=~/.config/i3blocks/scripts/disk_root /
interval=30

# [disk_home]
# uncomment if /home is on a separate partition
# command=~/.config/i3blocks/scripts/disk_home /home
# interval=30

[fan]
command=~/.config/i3blocks/scripts/fan
interval=5

[docker]
command=~/.config/i3blocks/scripts/docker
interval=10

[k8s]
command=~/.config/i3blocks/scripts/k8s
interval=10

[updates]
command=~/.config/i3blocks/scripts/updates
interval=3600

[systemd]
command=~/.config/i3blocks/scripts/systemd
interval=300

[ssh]
command=~/.config/i3blocks/scripts/ssh
interval=30

[github]
command=~/.config/i3blocks/scripts/github
interval=300

[bluetooth]
command=~/.config/i3blocks/scripts/bluetooth
interval=10

# [keyboard]
# command=~/.config/i3blocks/scripts/keyboard
# interval=once

[battery]
command=~/.config/i3blocks/scripts/battery
interval=30

[uptime]
command=awk '{h=int($1/3600); m=int(($1%3600)/60); printf "%dh %dm\n", h, m}' /proc/uptime
interval=60

[date]
command=date '+%a %d %b %H:%M'
interval=1
